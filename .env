# ============================================================
# PMA-DTR Docker Environment Configuration
# ============================================================
# Copy this file to `.env` at the project root before running:
#   cp .env.docker .env
#
# Then run:
#   docker compose up -d --build
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Docker MySQL requires a root password (unlike your local XAMPP/MySQL).
# This is the ONLY value that differs from your local setup.
DB_ROOT_PASSWORD=root
DB_NAME=pma_dtr
DB_EXTERNAL_PORT=3306

# ── Backend (Express) ───────────────────────────────────────
SESSION_SECRET=pma-secret-dtr
SERVER_PORT=5000

# ── Frontend ─────────────────────────────────────────────────
# Since Nginx proxies /api/ to Express, the frontend calls the
# same origin. VITE_API_BASE_URL must be empty string.
# Only change CLIENT_URL to your server's IP.
VITE_API_BASE_URL=http://192.168.1.17/api
CLIENT_URL=http://192.168.1.17
FRONTEND_PORT=80
